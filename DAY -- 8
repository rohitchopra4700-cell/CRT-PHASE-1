//   1.3 -- hierarchial  inheritance 
      
       class Vehicle {
           public:
             void start (){
                 cout <<" Vehicle start....";
             }
       };
          class Bike : public Vehicle{
              public:
               void drive(){
                   cout << " Bike is running ...." << "\n";
                   
               }
          };
              class Car : public Vehicle {
                  public:
                  void drive(){
                       cout << " Car  is running...." << "\n";
                      
                  }
              };
              int main(){
                  Car c; 
                  Bike b;
                  c.start();
                  c.drive();
                  c.start();
                  b.drive();
              }
